# 🎯 Person Following Robot - Environment Configuration
# Copy to .env and modify as needed

# ============================================================================
# THREAD OPTIMIZATION (Critical for performance)
# ============================================================================
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1
NUMEXPR_NUM_THREADS=1

# ============================================================================
# CAMERA SETTINGS
# ============================================================================
CAMERA_ID=0
CAMERA_WIDTH=320
CAMERA_HEIGHT=240
CAMERA_FPS=30
FORCE_USB_CAMERA=false

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
MODEL_PATH=models/yolov5nu_person_224_int8.onnx
INPUT_SIZE=224
CONF_THRESH=0.45
IOU_THRESH=0.25

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
AI_FPS_TARGET=15
GC_INTERVAL=500
ENABLE_MEMORY_CLEANUP=true

# ============================================================================
# NAVIGATION PARAMETERS
# ============================================================================
SAFE_DISTANCE_MM=1500
DEADZONE_X=15
DEADZONE_Z=100
KP_LINEAR=0.0008
KP_ANGULAR=0.015
MAX_LINEAR_SPEED=0.8
MAX_ANGULAR_SPEED=1.0

# ============================================================================
# TRACKING SETTINGS
# ============================================================================
TRACK_THRESH=0.50
TRACK_BUFFER=60
MATCH_THRESH=0.85

# ============================================================================
# DEBUG & LOGGING
# ============================================================================
DEBUG_MODE=false
LOG_LEVEL=INFO
SHOW_DEPTH_WINDOW=false
