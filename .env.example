# SentientFollowAI Environment Variables

# System
DEBUG_MODE=false
LOG_LEVEL=INFO

# Camera
CAMERA_ID=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# Models
MODEL_PATH=models/vision/yolov10n_openvino_model/yolov10n.xml

# Performance
MAX_THREADS=4
ENABLE_GPU=false

# Modules
ENABLED_MODULES=vision_tracking
